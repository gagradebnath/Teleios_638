{
  "platform": "teleios",
  "version": "1.0.0",
  "debug": false,
  "log_level": "INFO",
  "gateway": {
    "host": "0.0.0.0",
    "port": 8000,
    "cors_origins": ["http://localhost:3000"],
    "max_request_size_mb": 50
  },
  "storage": {
    "vector_backend": "chroma",
    "vector_collection": "teleios_docs",
    "db_url": "sqlite+aiosqlite:///./data/teleios.db",
    "upload_dir": "./data/uploads"
  },
  "ocr": {
    "engine": "easyocr",
    "equation_detection": true,
    "figure_extraction": true,
    "table_extraction": true
  },
  "sandbox": {
    "timeout_seconds": 10,
    "allowed_modules": ["math", "sympy", "numpy", "scipy", "matplotlib"]
  }
}
