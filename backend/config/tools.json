{
    "tools": [
        {
            "name": "vector_search",
            "description": "Semantic similarity search against the indexed document collection",
            "input_schema": {
                "query": "string",
                "top_k": "integer",
                "collection": "string"
            },
            "output_schema": {
                "results": "array<{text, source, score, doc_id, page}>"
            },
            "permissions": {
                "retrieval_agent": true,
                "explanation_agent": true,
                "qa_agent": true
            }
        },
        {
            "name": "sql_query",
            "description": "Parameterized SQL query against PostgreSQL",
            "input_schema": {
                "query": "string",
                "params": "array"
            },
            "output_schema": {
                "rows": "array",
                "count": "integer"
            },
            "permissions": {
                "qa_agent":true,
                "prediction_agent":true,
                "explanation_agent":true
            }
        },
        {
            "name": "python_exec",
            "description": "Sandboxed Python execution with math/science libraries",
            "input_schema": {
                "code": "string",
                "timeout_seconds": "integer"
            },
            "output_schema": {
                "stdout": "string",
                "figures": "array<base64>",
                "error": "string"
            },
            "permissions": {
                "execution_agent":true
            }
        },
        {
            "name": "document_retrieval",
            "description": "Retrieve raw or parsed document blocks by ID or page reference",
            "input_schema": {
                "doc_id": "string",
                "page": "integer",
                "block_type": "string"
            },
            "output_schema": {
                "blocks": "array<DocumentBlock>"
            },
            "permissions": {
                "document_agent":true,
                "retrieval_agent":true,
                "explanation_agent":true
            }
        },
        {
            "name": "stats_analysis",
            "description": "Compute topic frequency distributions, recency curves, similarity scores",
            "input_schema": {
                "operation": "string",
                "data": "array"
            },
            "output_schema": {
                "result": "object"
            },
            "permissions": {
                "qa_agent":true,
                "prediction_agent":true
            }
        }
    ]
}